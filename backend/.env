# The Google Cloud Project ID where Vertex AI is enabled
GOOGLE_CLOUD_PROJECT=mineral-hangar-495105-r3

# The region for Vertex AI (using asia-south1 as requested)
GOOGLE_CLOUD_LOCATION=asia-south1

# Connection string for your Cloud SQL / Postgres database
# Format: postgresql://<DB_USER>:<DB_PASS>@<DB_IP>:5432/<DB_NAME>
# Example: postgresql://postgres:mypassword@35.1.2.3:5432/syncsphere
DATABASE_URL=your_database_url_here

# Port for the backend server
PORT=5000
